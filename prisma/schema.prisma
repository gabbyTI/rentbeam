// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/client"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                String   @id @default(uuid())
  cognitoId         String?  @unique
  email             String   @unique
  notificationEmail String?
  name              String
  phone             String?
  businessName      String?
  taxId             String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  landlordAccount   LandlordAccount?
  tenantMemberships TenantMembership[]

  @@map("users")
}

model LandlordAccount {
  id                     String   @id @default(uuid())
  userId                 String   @unique
  user                   User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  payoutsEnabled         Boolean  @default(false)
  stripeAccountId        String?
  defaultDueDay          Int      @default(1)
  defaultGracePeriodDays Int      @default(5)
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  properties Property[]

  @@map("landlord_accounts")
}

model Property {
  id                   String          @id @default(uuid())
  landlordId           String
  landlord             LandlordAccount @relation(fields: [landlordId], references: [id], onDelete: Cascade)
  name                 String
  address              String
  acceptOnlinePayments Boolean         @default(true)
  createdAt            DateTime        @default(now())
  updatedAt            DateTime        @updatedAt

  units Unit[]

  @@index([landlordId])
  @@map("properties")
}

model Unit {
  id              String   @id @default(uuid())
  propertyId      String
  property        Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  name            String
  rentAmount      Decimal  @db.Decimal(10, 2)
  dueDay          Int
  gracePeriodDays Int      @default(5)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  tenantMemberships TenantMembership[]

  @@index([propertyId])
  @@map("units")
}

model TenantMembership {
  id         String @id @default(uuid())
  userId     String
  user       User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  unitId     String
  unit       Unit   @relation(fields: [unitId], references: [id], onDelete: Cascade)
  landlordId String

  moveInDate  DateTime
  moveOutDate DateTime?
  movedOutAt  DateTime?

  inviteStatus InviteStatus @default(PENDING)
  inviteToken  String?      @unique

  autopayEnabled         Boolean   @default(false)
  autopayDisabledAt      DateTime?
  autopayDisableReason   String?
  autopayConsentAt       DateTime?
  autopayFailureCount    Int       @default(0)
  lastAutopayFailureAt   DateTime?
  stripeCustomerId       String?
  defaultPaymentMethodId String?
  paymentMethodLabel     String?

  status    MembershipStatus @default(ACTIVE)
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  payments Payment[]

  @@index([userId])
  @@index([unitId])
  @@index([landlordId])
  @@index([inviteToken])
  @@map("tenant_memberships")
}

enum InviteStatus {
  PENDING
  ACCEPTED
}

enum MembershipStatus {
  ACTIVE
  INACTIVE
}

model Payment {
  id                 String           @id @default(uuid())
  tenantMembershipId String
  tenantMembership   TenantMembership @relation(fields: [tenantMembershipId], references: [id], onDelete: Cascade)

  // Amount breakdown
  rentAmount    Decimal @default(0) @db.Decimal(10, 2)
  processingFee Decimal @default(0) @db.Decimal(10, 2)
  platformFee   Decimal @default(0) @db.Decimal(10, 2)
  totalAmount   Decimal @default(0) @db.Decimal(10, 2)

  // Legacy field for backward compatibility
  amount Decimal @db.Decimal(10, 2)

  method PaymentMethod
  status PaymentStatus @default(SUCCEEDED)
  date   DateTime
  month  String // Format: "2025-01"
  note   String?

  stripePaymentIntentId String?

  createdAt DateTime @default(now())

  @@index([tenantMembershipId])
  @@index([month])
  @@index([status])
  @@map("payments")
}

enum PaymentMethod {
  CARD
  MANUAL
}

enum PaymentStatus {
  PENDING
  SUCCEEDED
  FAILED
}
