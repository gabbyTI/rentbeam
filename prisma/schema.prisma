// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/client"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                String   @id @default(uuid())
  cognitoId         String?  @unique
  email             String   @unique
  notificationEmail String?
  name              String   // Computed: firstName + lastName (for display)
  firstName         String?
  lastName          String?
  country           String?  // US or CA
  phone             String?
  businessName      String?
  taxId             String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  landlordAccount   LandlordAccount?
  tenantMemberships TenantMembership[]
  otpVerifications  OtpVerification[]

  @@map("users")
}

model LandlordAccount {
  id                     String   @id @default(uuid())
  userId                 String   @unique
  user                   User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  payoutsEnabled         Boolean  @default(false)
  stripeAccountId        String?
  defaultDueDay          Int      @default(1)
  defaultGracePeriodDays Int      @default(5)
  useBusinessName        Boolean  @default(false) // Show business name to tenants instead of personal name
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  properties Property[]

  @@map("landlord_accounts")
}

model Property {
  id                   String          @id @default(uuid())
  landlordId           String
  landlord             LandlordAccount @relation(fields: [landlordId], references: [id], onDelete: Cascade)
  name                 String
  address              String          // Computed display string (streetAddress, city, province postalCode)
  streetAddress        String          @default("")
  city                 String          @default("")
  province             String          @default("")
  postalCode           String          @default("")
  country              String          @default("CA")
  acceptOnlinePayments Boolean         @default(true)
  createdAt            DateTime        @default(now())
  updatedAt            DateTime        @updatedAt

  units Unit[]

  @@index([landlordId])
  @@map("properties")
}

model Unit {
  id              String   @id @default(uuid())
  propertyId      String
  property        Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  name            String
  rentAmount      Decimal  @db.Decimal(10, 2)
  dueDay          Int
  gracePeriodDays Int      @default(5)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  tenantMemberships TenantMembership[]

  @@index([propertyId])
  @@map("units")
}

model TenantMembership {
  id         String @id @default(uuid())
  userId     String
  user       User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  unitId     String
  unit       Unit   @relation(fields: [unitId], references: [id], onDelete: Cascade)
  landlordId String

  moveInDate  DateTime
  moveOutDate DateTime?
  movedOutAt  DateTime?

  inviteStatus InviteStatus @default(PENDING)
  inviteToken  String?      @unique

  autopayEnabled         Boolean   @default(false)
  autopayDisabledAt      DateTime?
  autopayDisableReason   String?
  autopayConsentAt       DateTime?
  autopayFailureCount    Int       @default(0)
  lastAutopayFailureAt   DateTime?
  stripeCustomerId       String?
  defaultPaymentMethodId String?
  paymentMethodLabel     String?
  mandateId              String?
  paymentMethodType      String?

  status    MembershipStatus @default(ACTIVE)
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  // Lease details
  leaseStartDate        DateTime?
  leaseEndDate          DateTime?
  leaseType             LeaseType  @default(FIXED_TERM)
  rentDeposit           Decimal?   @db.Decimal(10, 2)

  // Tenant profile
  dateOfBirth           DateTime?
  emergencyContactName  String?
  emergencyContactPhone String?
  notes                 String?

  payments    Payment[]
  documents   TenantDocument[]

  @@index([userId])
  @@index([unitId])
  @@index([landlordId])
  @@index([inviteToken])
  @@map("tenant_memberships")
}

enum LeaseType {
  FIXED_TERM
  MONTH_TO_MONTH
}

enum InviteStatus {
  PENDING
  ACCEPTED
}

enum MembershipStatus {
  ACTIVE
  INACTIVE
}

model TenantDocument {
  id                 String           @id @default(uuid())
  tenantMembershipId String
  tenantMembership   TenantMembership @relation(fields: [tenantMembershipId], references: [id], onDelete: Cascade)
  type               DocumentType
  fileName           String
  fileKey            String
  fileSize           Int
  mimeType           String
  uploadedByUserId   String
  notes              String?
  createdAt          DateTime         @default(now())

  @@index([tenantMembershipId])
  @@map("tenant_documents")
}

enum DocumentType {
  LEASE
  MOVE_IN_INSPECTION
  MOVE_OUT_INSPECTION
  NOTICE
  ID_VERIFICATION
  OTHER
}

model Payment {
  id                 String           @id @default(uuid())
  tenantMembershipId String
  tenantMembership   TenantMembership @relation(fields: [tenantMembershipId], references: [id], onDelete: Cascade)

  // Amount breakdown
  rentAmount    Decimal @default(0) @db.Decimal(10, 2)
  processingFee Decimal @default(0) @db.Decimal(10, 2)
  platformFee   Decimal @default(0) @db.Decimal(10, 2)
  totalAmount   Decimal @default(0) @db.Decimal(10, 2)

  // Legacy field for backward compatibility
  amount Decimal @db.Decimal(10, 2)

  method PaymentMethod
  status PaymentStatus @default(SUCCEEDED)
  date   DateTime
  month  String // Format: "2025-01"
  note   String?

  stripePaymentIntentId String? @unique

  createdAt DateTime @default(now())

  @@index([tenantMembershipId])
  @@index([month])
  @@index([status])
  @@map("payments")
}

enum PaymentMethod {
  CARD
  MANUAL
}

enum PaymentStatus {
  PENDING
  PROCESSING  // Bank transfer initiated, awaiting confirmation
  SUCCEEDED
  FAILED
}

model OtpVerification {
  id             String   @id @default(uuid())
  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type           OtpType
  hashedCode     String
  metadata       Json
  expiresAt      DateTime
  verifyAttempts Int      @default(0)
  createdAt      DateTime @default(now())

  @@index([userId, type])
  @@index([expiresAt])
  @@map("otp_verifications")
}

enum OtpType {
  NOTIFICATION_EMAIL
}
